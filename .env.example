# Anthropic API Key (从 console.anthropic.com 获取)
export ANTHROPIC_API_KEY="sk-ant-..."

# 或者使用 OAuth bearer token（用于代理）
# export ANTHROPIC_AUTH_TOKEN="bearer-token"

# 可选：自定义 API 端点
# export ANTHROPIC_BASE_URL="https://your-proxy.com"

# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的 API Key
# 3. 运行: source .env
# 4. 启动: ./target/debug/my-cli
